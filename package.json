{
  "name": "recipebook",
  "version": "1.0.0",
  "scripts": {
    "build": "npm install && npm run build:frontend && npm run install:backend",
    "build:frontend": "npx vite build",
    "install:backend": "cd backend && npm install",
    "start": "node backend/server.js",
    "dev": "concurrently \"npx vite\" \"node backend/server.js\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "vite": "^5.4.10"
  }
}
